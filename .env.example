# OPENAI_API_KEY: Required for the AI features (reading content, progress insight,
# and adaptive session planning). Set it in .env.local for local development.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: Optional. Chat model used for the AI features. Defaults to gpt-4o-mini.
OPENAI_MODEL="gpt-4o-mini"

# APP_URL: The URL where this app is hosted (optional, for self-referential links).
APP_URL="MY_APP_URL"
